# Codeblue — environment configuration.
# With nothing set below, the app runs entirely in sim mode: scripted demo
# call, simulated vitals, guest access. That's the default and it's fully
# demoable with zero keys.

# --- ElevenLabs (PRD 6.1) ---
# Server-side only — never exposed to the browser.
ELEVENLABS_API_KEY=

# One conversational agent per case type. The scenario/level picks which agent
# to call (see src/app/api/call/token/route.ts). Each agent's persona, first
# message, and voice are configured on the ElevenLabs dashboard. Add more
# ELEVENLABS_<CASE>_AGENT_ID vars as you add cases; leave any blank (or the
# API key blank) to fall back to the scripted sim call.
# Recommended per agent: a fast LLM (e.g. gemini-2.5-flash, thinking disabled),
# a turbo/flash v2 TTS model (e.g. eleven_flash_v2 — required for English
# agents) for lowest latency, and eager turn-taking.
ELEVENLABS_ROBBERY_AGENT_ID=
ELEVENLABS_ASSAULT_AGENT_ID=
# Placeholders — create the agents and fill these in as you add cases/levels.
ELEVENLABS_FIRE_AGENT_ID=
ELEVENLABS_CARDIAC_AGENT_ID=
ELEVENLABS_DOMESTIC_AGENT_ID=

# --- Presage SmartSpectra (PRD 6.2 / 14 open question #1) ---
# Server-side only. SmartSpectra's Node SDK (@smartspectra/node-sdk) is
# native-FFI and headless-only — there's no browser SDK — so the browser
# streams webcam frames to /api/vitals/frame and this key feeds a
# persistent per-session SDK instance in src/lib/presage-server.ts. Get a
# key from the developer portal at https://smartspectra.presagetech.com/.
# Only works when API routes run in one long-lived Node process (self-hosted
# `next start`, not a cold-start-per-request serverless deploy). Leave blank
# to fall back to the vitals sim in src/lib/vitals-sim.ts.
PRESAGE_API_KEY=

# --- Demo controls (PRD "Demo" props on the imported design) ---
NEXT_PUBLIC_BASELINE_SECONDS=15
NEXT_PUBLIC_DEMO_SPEED=1

# --- Auth0 (P2, PRD 6.11) ---
# Guest mode (no login) is the default and is what judges should see. Set to
# true once APP_BASE_URL/AUTH0_* below are filled in to require real sign-in
# (still shows a "Try the demo" button that bypasses login).
NEXT_PUBLIC_AUTH_ENABLED=false

# @auth0/nextjs-auth0 v4. Get these from an Auth0 Regular Web Application
# (Application URIs -> Allowed Callback URLs: <APP_BASE_URL>/auth/callback,
# Allowed Logout URLs: <APP_BASE_URL>/). AUTH0_SECRET is a 32+ byte random
# string (`openssl rand -hex 32`) used to encrypt the session cookie.
# Google, enterprise SSO, and passwordless email are enabled per-connection
# in the Auth0 dashboard (Authentication -> Social / Enterprise /
# Passwordless) — once enabled there, Universal Login surfaces them
# automatically with no app code changes.
APP_BASE_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
